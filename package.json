    "test:mobile:all": "wdio run tests/mobile/wdio.conf.ts --spec tests/mobile/specs/comprehensive-auth-test.e2e.ts tests/mobile/specs/maintenance-workflow-test.e2e.ts tests/mobile/specs/dedicated-vendors-test.e2e.ts tests/mobile/specs/profile-navigation-test.e2e.ts",
    "migrate": "tsx scripts/runMigration.ts",
