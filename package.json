{
  "name": "lalarente-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit --skipLibCheck",
    "test": "jest",
    "test:e2e": "bash scripts/run-e2e.sh",
    "test:e2e:shipped": "bash scripts/run-e2e.sh .maestro/flows/build5-shipped-suite.yaml",
    "test:e2e:video": "bash scripts/run-e2e-video.sh",
    "test:e2e:record": "bash scripts/record-e2e.sh",
    "supabase:types": "npx supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/core/types/database.ts",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=24.4.1 <25.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.4.5",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "^8.13.0",
    "@supabase/supabase-js": "^2.75.0",
    "@tanstack/react-query": "^5.90.3",
    "base64-arraybuffer": "^1.0.2",
    "date-fns": "^4.4.0",
    "expo": "~54.0.13",
    "expo-av": "~16.0.7",
    "expo-blur": "^15.0.7",
    "expo-constants": "~18.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.9",
    "expo-haptics": "^15.0.7",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "^15.0.7",
    "expo-linking": "~8.0.8",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.11",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "~15.0.8",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-google-places-autocomplete": "^2.6.1",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-signature-canvas": "^5.0.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "supabase": "^2.51.0",
    "tailwindcss": "^3.4.18",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.37.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.16",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "private": true
}
